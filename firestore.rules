rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email != null && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "kazih6684@gmail.com" && isEmailVerified())
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Staff Member Validation
    function isValidStaffMember(data) {
      return data.keys().hasAll(['name', 'category', 'method', 'number', 'createdAt', 'createdBy']) &&
             data.keys().size() <= 8 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             data.category in ['Senior Team Leader', 'Team Leader', 'Counselor', 'Senior Counselor', 'Teacher', 'Team Trainer'] &&
             data.method in ['bKash', 'Nagad', 'Rocket'] &&
             data.number is string && data.number.size() >= 10 && data.number.size() <= 20 &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time &&
             (!('order' in data) || data.order is number);
    }

    match /staff/{staffId} {
      allow read: if true; // Public directory
      
      allow create: if isAdmin() && 
                      isValidId(staffId) && 
                      isValidStaffMember(incoming());

      allow update: if isAdmin() && 
                      isValidId(staffId) && 
                      isValidStaffMember(incoming()) &&
                      incoming().createdBy == existing().createdBy &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'method', 'number', 'order']);

      allow delete: if isAdmin() && isValidId(staffId);
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidId(adminId);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId);
    }
  }
}
